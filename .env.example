# Copy to .env when implementing (do not commit real keys)

# Translation fallback: none | mymemory | libre | deepl
MT_PROVIDER=mymemory

# MyMemory (optional email for higher free quota)
# MYMEMORY_EMAIL=

# LibreTranslate self-hosted
# LIBRETRANSLATE_URL=http://localhost:5000

# DeepL Free
# DEEPL_API_KEY=

# ODA File Converter (Windows path example)
# ODA_FC_PATH=C:\Program Files\ODA\ODAFileConverter\ODAFileConverter.exe

# Worker
# WORKER_MAX_UPLOAD_MB=50
# GLOSSARY_PATH=./data/semantic-glossary.xlsx
